// MJ - Biochemistry AI Tool
// Frontend JavaScript - Main Script

const API_URL = "http://localhost:5000";

// ============ SEQUENCE ANALYSIS ============

async function analyzeSequence() {
    const sequence = document.getElementById('sequenceInput').value;
    
    if (!sequence.trim()) {
        alert('Please enter a sequence');
        return;
    }
    
    const resultBox = document.getElementById('sequenceResult');
    resultBox.innerHTML = '<p>⏳ Analyzing...</p>';
    resultBox.classList.add('active');
    
    try {
        const response = await fetch(`${API_URL}/api/analyze-sequence`, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
            },
            body: JSON.stringify({ sequence: sequence })
        });
        
        const data = await response.json();
        
        if (data.success) {
            const result = data.analysis;
            let html = `
                <h4>✅ Analysis Results:</h4>
                <p><strong>Sequence Type:</strong> ${result.sequence_type}</p>
                <p><strong>Length:</strong> ${result.length} bp/aa</p>
            `;
            
            if (result.gc_content) {
                html += `<p><strong>GC Content:</strong> ${result.gc_content}%</p>`;
            }
            
            if (result.nucleotide_counts) {
                html += `<p><strong>Nucleotides:</strong></p>`;
                html += `<ul>`;
                for (const [key, val] of Object.entries(result.nucleotide_counts)) {
                    if (val > 0) html += `<li>${key}: ${val}</li>`;
                }
                html += `</ul>`;
            }
            
            resultBox.innerHTML = html;
        } else {
            resultBox.innerHTML = `<p style="color: red;">❌ Error: ${data.error}</p>`;
        }
    } catch (error) {
        resultBox.innerHTML = `
            <p style="color: red;">
                ❌ Cannot connect to API server
            </p>
            <p style="font-size: 0.9rem; color: #666;">
                Make sure Flask server is running: python server.py
            </p>
        `;
    }
}

// ============ HEALTH CHECK ============

async function checkHealth() {
    const resultBox = document.getElementById('healthResult');
    resultBox.innerHTML = '<p>⏳ Checking API health...</p>';
    resultBox.classList.add('active');
    
    try {
        const response = await fetch(`${API_URL}/api/health`);
        const data = await response.json();
        
        if (data.status === 'healthy') {
            resultBox.innerHTML = `
                <h4>✅ API Status: HEALTHY</h4>
                <p><strong>App:</strong> ${data.app}</p>
                <p><strong>Version:</strong> ${data.version}</p>
                <p style="color: green; margin-top: 1rem;">🟢 Server is running and ready!</p>
            `;
        } else {
            resultBox.innerHTML = `<p style="color: red;">❌ API is not healthy</p>`;
        }
    } catch (error) {
        resultBox.innerHTML = `
            <p style="color: red;">
                ❌ Cannot connect to API server
            </p>
            <p style="font-size: 0.9rem;">
                To start the server, run: <code>python server.py</code>
            </p>
        `;
    }
}

// ============ ANALYZE WITH USER ============

async function analyzeWithUser() {
    const sequence = document.getElementById('advSequenceInput').value;
    const userId = localStorage.getItem('user_id');
    
    if (!sequence.trim()) {
        alert('Please enter a sequence');
        return;
    }
    
    if (!userId) {
        alert('Please login first to save analysis');
        return;
    }
    
    try {
        const response = await fetch(`${API_URL}/api/analyze-sequence`, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
            },
            body: JSON.stringify({
                sequence: sequence,
                user_id: parseInt(userId)
            })
        });
        
        const data = await response.json();
        
        if (data.success) {
            alert('✅ Analysis saved to your profile!');
            document.getElementById('advSequenceInput').value = '';
        } else {
            alert(`❌ Error: ${data.error}`);
        }
    } catch (error) {
        alert(`❌ Error: ${error.message}`);
    }
}

// ============ NAVIGATION ============

document.querySelectorAll('a[href^="#"]').forEach(anchor => {
    anchor.addEventListener('click', function (e) {
        e.preventDefault();
        const target = document.querySelector(this.getAttribute('href'));
        if (target) {
            target.scrollIntoView({
                behavior: 'smooth',
                block: 'start'
            });
        }
    });
});

// ============ INITIALIZATION ============

document.addEventListener('DOMContentLoaded', function() {
    console.log('🧬 MJ - Biochemistry AI Tool loaded');
    console.log('📡 API URL:', API_URL);
    console.log('✅ Ready to analyze sequences!');
    
    // Hide result boxes initially
    const resultBoxes = document.querySelectorAll('.result-box');
    resultBoxes.forEach(box => box.classList.remove('active'));
});

// ============ UTILITIES ============

function showAlert(message, type = 'info') {
    const alertBox = document.createElement('div');
    alertBox.style.cssText = `
        position: fixed;
        top: 20px;
        right: 20px;
        padding: 1rem;
        background: ${type === 'error' ? '#ff6b6b' : '#51cf66'};
        color: white;
        border-radius: 5px;
        z-index: 1000;
    `;
    alertBox.textContent = message;
    document.body.appendChild(alertBox);
    
    setTimeout(() => alertBox.remove(), 3000);
}

// ============ KEYBOARD SHORTCUTS ============

document.addEventListener('keydown', function(event) {
    // Ctrl/Cmd + Enter to analyze
    if ((event.ctrlKey || event.metaKey) && event.key === 'Enter') {
        const activeInput = document.activeElement;
        if (activeInput && activeInput.tagName === 'TEXTAREA') {
            if (activeInput.id === 'sequenceInput') {
                analyzeSequence();
            } else if (activeInput.id === 'advSequenceInput') {
                analyzeWithUser();
            }
        }
    }
});

